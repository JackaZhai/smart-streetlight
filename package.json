{
  "name": "smart-streetlight",
  "version": "0.1.0",
  "private": true,
  "description": "智慧路灯节能系统 TypeScript 全栈初稿",
  "workspaces": [
    "backend",
    "frontend",
    "mock-device"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:mock": "npm --workspace mock-device run dev",
    "db:backup": "node scripts/db-backup.mjs",
    "db:restore": "node scripts/db-restore.mjs",
    "build": "npm --workspaces --if-present run build",
    "test": "npm run test:ops && npm --workspaces --if-present run test",
    "test:ops": "node --test scripts/*.test.mjs",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
